// Begin ZK6100HGA

spriteset (spriteset_ZK6100HGA_purchase, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase_32bpp ("Two-Axle", "ZK6100HGA")
}

spriteset (spriteset_ZK6100HGA_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "ZK6100HGA")
}

spriteset (spriteset_ZK6100HGA_TJ, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "ZK6100HGA_TJ")
}

spriteset (spriteset_ZK6100HGA_TJ_YING, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "ZK6100HGA_YING_TJ")
}

spriteset (spriteset_ZK6100HGA_TJBH, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "ZK6100HGA_TJBH")
}

spriteset (spriteset_ZK6100HGA_TJBH_WHITE, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "ZK6100HGA_WHITE_TJBH")
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6100HGA_cargo_subtype, cargo_subtype) {
    0: return string(STR_ORIGINAL);
    1: return string(STR_TJ);
    2: return string(STR_TJ_YING);
    3: return string(STR_TJBH);
    4: return string(STR_TJBH_WHITE);
    return CB_RESULT_NO_TEXT;
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6100HGA_cargo_graphics, cargo_subtype) {
    0: spriteset_ZK6100HGA_original;
    1: spriteset_ZK6100HGA_TJ;
    2: spriteset_ZK6100HGA_TJ_YING;
    3: spriteset_ZK6100HGA_TJBH;
    4: spriteset_ZK6100HGA_TJBH_WHITE;
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6100HGA_graphics, position_in_articulated_veh) {
    1: switch_ZK6100HGA_cargo_graphics;
    empty_sprites;
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6100HGA_articulated_part, extra_callback_info1) {
    1..2 : return ZK6100HGA;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

item (FEAT_ROADVEHS, ZK6100HGA) {
    property {
        sprite_id:                      SPRITE_ID_NEW_ROADVEH;
        climates_available:             ALL_CLIMATES;
        running_cost_base:              RUNNING_COST_ROADVEH;
        refit_cost:                     0;
        misc_flags:                     bitmask(ROADVEH_FLAG_AUTOREFIT);

        cost_factor:                    1;
        running_cost_factor:            1;

        length:                         7;
        refittable_cargo_classes:       bitmask(CC_PASSENGERS);
        cargo_allow_refit:              [PASS, TOUR, YETI, YETY];
        default_cargo_type:             PASS;

        name:                           string(STR_NAME_ZK6100HGA);
        introduction_date:              date(2010,1,1);
        model_life:                     60;
        retire_early:                   50;
        vehicle_life:                   13;
        reliability_decay:              12;

        power:                          180 kW;
        weight:                         10.6 ton;
        tractive_effort_coefficient:    0.3;
        speed:                          90 km/h;

        cargo_capacity:                 26;
        loading_speed:                  40 << param_loading_speed;
        cargo_age_period:               123 << param_cargo_decay;
    }
    graphics {
        default:                        switch_ZK6100HGA_graphics;
        purchase:                       spriteset_ZK6100HGA_purchase;
        cargo_subtype_text:             switch_ZK6100HGA_cargo_subtype;
        length:                         switch_1_8_1_length_10;
        articulated_part:               switch_ZK6100HGA_articulated_part;
        additional_text:                string(STR_DESC_4, string(STR_TYPE_URBAN), string(STR_SIZE_LARGE), string(STR_COMFORT, 123 ,string(STR_CLASS_ORIDINARY)), string(STR_LOADING_SPEED, 40));

        cost_factor:                    189;
        running_cost_factor:            2 * runningcostfactor();
        purchase_running_cost_factor:   2 * 8;
    }
}

// End ZK6100HGA