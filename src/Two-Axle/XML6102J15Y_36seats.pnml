switch (FEAT_ROADVEHS, SELF, switch_XML6102J15Y_36seats_name, getbits(extra_callback_info1, 0, 8) == 0x20? getbits(extra_callback_info1, 8, 8) : 0xFFFF) {
    0: return string(STR_LIST_XML6102J15Y);
    return CB_RESULT_NO_TEXT;
}

spriteset (spriteset_XML6102J15Y_36seats_purchase, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase_32bpp ("Two-Axle", "XML6102J15Y")
}

spriteset (spriteset_XML6102J15Y_36seats_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "XML6102J15Y")
}

switch (FEAT_ROADVEHS, SELF, switch_XML6102J15Y_36seats_graphics, position_in_articulated_veh) {
    1: spriteset_XML6102J15Y_36seats_original;
    empty_sprites;
}

switch (FEAT_ROADVEHS, SELF, switch_XML6102J15Y_36seats_articulated_part, extra_callback_info1) {
    1..2 : return XML6102J15Y_36seats;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

