// Begin LCK6820HG

spriteset (spriteset_LCK6820HG_purchase, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase_32bpp ("Two-Axle", "LCK6820HG_YG")
}

spriteset (spriteset_LCK6820HG_YG_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_0 ("Two-Axle", "LCK6820HG_YG")
}

spriteset (spriteset_LCK6820HG_YG_TJ, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_0 ("Two-Axle", "LCK6820HG_YG_TJ")
}

spriteset (spriteset_LCK6820HG_FC_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_0 ("Two-Axle", "LCK6820HG_FC")
}

switch (FEAT_ROADVEHS, SELF, switch_LCK6820HG_cargo_subtype, cargo_subtype) {
    0: return string(STR_YG_ORIGINAL);
    1: return string(STR_YG_TJ);
    2: return string(STR_FC_ORIGINAL);
    return CB_RESULT_NO_TEXT;
}

switch (FEAT_ROADVEHS, SELF, switch_LCK6820HG_graphics, cargo_subtype) {
    0: spriteset_LCK6820HG_YG_original;
    1: spriteset_LCK6820HG_YG_TJ;
    2: spriteset_LCK6820HG_FC_original;
}

item (FEAT_ROADVEHS, LCK6820HG) {
    property {
        sprite_id:                      SPRITE_ID_NEW_ROADVEH;
        climates_available:             ALL_CLIMATES;
        running_cost_base:              RUNNING_COST_ROADVEH;
        refit_cost:                     0;
        misc_flags:                     bitmask(ROADVEH_FLAG_AUTOREFIT);
        cost_factor:                    1;
        running_cost_factor:            1;

        length:                         7;
        refittable_cargo_classes:       bitmask(CC_PASSENGERS);
        cargo_allow_refit:              [PASS, TOUR, YETI, YETY];
        default_cargo_type:             PASS;

        name:                           string(STR_NAME_LCK6820HG);
        introduction_date:              date(2013,02,18);
        model_life:                     60;
        retire_early:                   50;
        vehicle_life:                   13;
        reliability_decay:              12;

        power:                          132 kW;
        weight:                         7.5 ton;
        tractive_effort_coefficient:    0.3;
        speed:                          70 km/h;

        cargo_capacity:                 58;
        loading_speed:                  30 << param_loading_speed;
        cargo_age_period:               112 << param_cargo_decay;
    }
    graphics {
        default:                        switch_LCK6820HG_graphics;
        purchase:                       spriteset_LCK6820HG_purchase;
        cargo_subtype_text:             switch_LCK6820HG_cargo_subtype;
        additional_text:                string(STR_DESC_4, string(STR_TYPE_URBAN), string(STR_SIZE_MEDIUM), string(STR_COMFORT, 112 ,string(STR_CLASS_ORIDINARY)), string(STR_LOADING_SPEED, 30));

        cost_factor:                    152;
        running_cost_factor:            2 * runningcostfactor();
        purchase_running_cost_factor:   2 * 8;
    }
}

// End LCK6820HG