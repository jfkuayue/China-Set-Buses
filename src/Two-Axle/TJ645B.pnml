// Begin TJ645B

spriteset (spriteset_TJ645B_purchase, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase_32bpp ("Two-Axle", "TJ645B_TJ")
}

spriteset (spriteset_TJ645B_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_0 ("Two-Axle", "TJ645B_TJ")
}


item (FEAT_ROADVEHS, TJ645B) {
    property {
        sprite_id:                      SPRITE_ID_NEW_ROADVEH;
        climates_available:             ALL_CLIMATES;
        running_cost_base:              RUNNING_COST_ROADVEH;
        refit_cost:                     0;
        misc_flags:                     bitmask(ROADVEH_FLAG_AUTOREFIT);
        cost_factor:                    1;
        running_cost_factor:            1;

        length:                         8;
        refittable_cargo_classes:       bitmask(CC_PASSENGERS);
        cargo_allow_refit:              [PASS, TOUR, YETI, YETY];
        default_cargo_type:             PASS;

        name:                           string(STR_NAME_TJ645B);
        introduction_date:              date(1978,12,1);
        model_life:                     60;
        retire_early:                   50;
        vehicle_life:                   20;
        reliability_decay:              16;

        power:                          70 kW;
        weight:                         6.5 ton;
        tractive_effort_coefficient:    0.3;
        speed:                          75 km/h;

        cargo_capacity:                 85;
        loading_speed:                  20 << param_loading_speed;
        cargo_age_period:               106 << param_cargo_decay;
    }
    graphics {
        default:                        spriteset_TJ645B_original;
        purchase:                       spriteset_TJ645B_purchase;
        additional_text:                string(STR_DESC_4, string(STR_TYPE_URBAN), string(STR_SIZE_MEDIUM), string(STR_COMFORT, 106 ,string(STR_CLASS_ORIDINARY)), string(STR_LOADING_SPEED, 20));

        cost_factor:                    102;
        running_cost_factor:            1 * runningcostfactor();
        purchase_running_cost_factor:   1 * 8;
    }
}

// End TJ645B