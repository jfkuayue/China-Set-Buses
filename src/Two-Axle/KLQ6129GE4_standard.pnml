// Begin KLQ6129GE4_STANDARD
switch (FEAT_ROADVEHS, SELF, switch_KLQ6129GE4_standard_name, getbits(extra_callback_info1, 0, 8) == 0x20? getbits(extra_callback_info1, 8, 8) : 0xFFFF) {
    0: return string(STR_LIST_KLQ6129GE4);
    return CB_RESULT_NO_TEXT;
}

spriteset (spriteset_KLQ6129GE4_standard_purchase, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase_32bpp ("Two-Axle", "KLQ6129GE4_1L_NOAIR")
}

spriteset (spriteset_KLQ6129GE4_standard_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "KLQ6129GE4_1L_NOAIR")
}

spriteset (spriteset_KLQ6129GE4_standard_2D, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "KLQ6129GE4_2D_1L_NOAIR")
}

switch (FEAT_ROADVEHS, SELF, switch_KLQ6129GE4_standard_cargo_subtype, cargo_subtype) {
    0: return string(STR_ORIGINAL);
    1: return string(STR_2D);
    return CB_RESULT_NO_TEXT;
}

switch (FEAT_ROADVEHS, SELF, switch_KLQ6129GE4_standard_cargo_graphics, cargo_subtype) {
    0: spriteset_KLQ6129GE4_standard_original;
    1: spriteset_KLQ6129GE4_standard_2D;
}

switch (FEAT_ROADVEHS, SELF, switch_KLQ6129GE4_standard_graphics, position_in_articulated_veh) {
    1: switch_KLQ6129GE4_standard_cargo_graphics;
    empty_sprites;
}

switch (FEAT_ROADVEHS, SELF, switch_KLQ6129GE4_standard_articulated_part, extra_callback_info1) {
    1..2 : return KLQ6129GE4_standard;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

item (FEAT_ROADVEHS, KLQ6129GE4_standard) {
    property {
        sprite_id:                      SPRITE_ID_NEW_ROADVEH;
        climates_available:             ALL_CLIMATES;
        running_cost_base:              RUNNING_COST_ROADVEH;
        refit_cost:                     0;
        misc_flags:                     bitmask(ROADVEH_FLAG_AUTOREFIT);

        cost_factor:                    1;
        running_cost_factor:            1;

        length:                         7;
        refittable_cargo_classes:       bitmask(CC_PASSENGERS);
        cargo_allow_refit:              [PASS, TOUR, YETI, YETY];
        default_cargo_type:             PASS;

        name:                           string(STR_NAME_KLQ6129GE4_STANDARD);
        introduction_date:              date(2011,1,1);
        model_life:                     60;
        retire_early:                   50;
        vehicle_life:                   13;
        reliability_decay:              12;

        power:                          191 kW;
        weight:                         11.4 ton;
        tractive_effort_coefficient:    0.3;
        speed:                          85 km/h;

        cargo_capacity:                 34;
        loading_speed:                  40 << param_loading_speed;
        cargo_age_period:               123 << param_cargo_decay;
    }
    graphics {
        default:                        switch_KLQ6129GE4_standard_graphics;
        purchase:                       spriteset_KLQ6129GE4_standard_purchase;
        cargo_subtype_text:             switch_KLQ6129GE4_standard_cargo_subtype;
        length:                         switch_2_7_2_length_11;
        articulated_part:               switch_KLQ6129GE4_standard_articulated_part;
        additional_text:                string(STR_DESC_4, string(STR_TYPE_URBAN), string(STR_SIZE_LARGE), string(STR_COMFORT, 123 ,string(STR_CLASS_ORIDINARY)), string(STR_LOADING_SPEED, 40));

        cost_factor:                    185;
        running_cost_factor:            2 * runningcostfactor();
        purchase_running_cost_factor:   2 * 8;
        name:                           switch_KLQ6129GE4_standard_name;
    }
}

// End KLQ6129GE4_STANDARD