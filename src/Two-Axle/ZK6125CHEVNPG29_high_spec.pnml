// Begin ZK6125CHEVNPG29_HIGH_SPEC

spriteset (spriteset_ZK6125CHEVNPG29_high_spec_purchase, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_purchase_32bpp ("Two-Axle", "ZK6125CHEVNPG29")
}

spriteset (spriteset_ZK6125CHEVNPG29_high_spec_original, ZOOM_LEVEL_IN_4X, BIT_DEPTH_32BPP) {
    template_standard_2 ("Two-Axle", "ZK6125CHEVNPG29")
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6125CHEVNPG29_high_spec_cargo_subtype, cargo_subtype) {
    0: return string(STR_ORIGINAL);
    return CB_RESULT_NO_TEXT;
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6125CHEVNPG29_high_spec_cargo_graphics, cargo_subtype) {
    0: spriteset_ZK6125CHEVNPG29_high_spec_original;
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6125CHEVNPG29_high_spec_graphics, position_in_articulated_veh) {
    1: switch_ZK6125CHEVNPG29_high_spec_cargo_graphics;
    empty_sprites;
}

switch (FEAT_ROADVEHS, SELF, switch_ZK6125CHEVNPG29_high_spec_articulated_part, extra_callback_info1) {
    1..2 : return ZK6125CHEVNPG29_high_spec;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
}

item (FEAT_ROADVEHS, ZK6125CHEVNPG29_high_spec) {
    property {
        sprite_id:                      SPRITE_ID_NEW_ROADVEH;
        climates_available:             ALL_CLIMATES;
        running_cost_base:              RUNNING_COST_ROADVEH;
        refit_cost:                     0;
        misc_flags:                     bitmask(ROADVEH_FLAG_AUTOREFIT);
        variant_group:					ZK6125CHEVNPG29_standard;

        cost_factor:                    1;
        running_cost_factor:            1;

        length:                         7;
        refittable_cargo_classes:       bitmask(CC_PASSENGERS);
        cargo_allow_refit:              [PASS, TOUR, YETI, YETY];
        default_cargo_type:             PASS;

        name:                           string(STR_NAME_ZK6125CHEVNPG29_HIGH_SPEC);
        introduction_date:              date(2017,1,1);
        model_life:                     60;
        retire_early:                   50;
        vehicle_life:                   13;
        reliability_decay:              8;

        power:                          155 kW;
        weight:                         13.75 ton;
        tractive_effort_coefficient:    0.3;
        speed:                          70 km/h;

        cargo_capacity:                 27;
        loading_speed:                  40 << param_loading_speed;
        cargo_age_period:               158 << param_cargo_decay;
    }
    graphics {
        default:                        switch_ZK6125CHEVNPG29_high_spec_graphics;
        purchase:                       spriteset_ZK6125CHEVNPG29_high_spec_purchase;
        cargo_subtype_text:             switch_ZK6125CHEVNPG29_high_spec_cargo_subtype;
        length:                         switch_2_7_2_length_11;
        articulated_part:               switch_ZK6125CHEVNPG29_high_spec_articulated_part;
        additional_text:                string(STR_DESC_4, string(STR_TYPE_URBAN), string(STR_SIZE_LARGE), string(STR_COMFORT, 158 ,string(STR_CLASS_HIGH_2)), string(STR_LOADING_SPEED, 40));

        cost_factor:                    204;
        running_cost_factor:            1 * runningcostfactor();
        purchase_running_cost_factor:   1 * 8;
        name:                           switch_ZK6125CHEVNPG29_standard_name;
    }
}

// End ZK6125CHEVNPG29_HIGH_SPEC